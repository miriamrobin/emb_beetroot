#include <Arduino.h>

#define LED1_PIN 18
#define LED2_PIN 19
#define BUTTON_EXT 23
#define BUTTON_BOOT 0

#define FAST_DELAY 200
#define SLOW_DELAY 1000
#define NORMAL_DELAY 500

int mode = 0;

void setup() {
  pinMode(LED1_PIN, OUTPUT);
  pinMode(LED2_PIN, OUTPUT);

  pinMode(BUTTON_EXT, INPUT_PULLUP);
  pinMode(BUTTON_BOOT, INPUT_PULLUP);

  Serial.begin(115200);
}

void loop() {

  if (digitalRead(BUTTON_EXT) == LOW) {
    mode = 1;
    Serial.println("Faster");
    delay(200);
  }

  if (digitalRead(BUTTON_BOOT) == LOW) {
    mode = 2;
    Serial.println("Slower");
    delay(200);
  }

  int delayTime;

  switch (mode) {
    case 1: delayTime = FAST_DELAY; break;
    case 2: delayTime = SLOW_DELAY; break;
    default: delayTime = NORMAL_DELAY;
  }

  digitalWrite(LED1_PIN, HIGH);
  digitalWrite(LED2_PIN, LOW);
  delay(delayTime);

  digitalWrite(LED1_PIN, LOW);
  digitalWrite(LED2_PIN, HIGH);
  delay(delayTime);
}
