#include <Arduino.h>

#define LED1_PIN 2
#define LED2_PIN 4
#define BLINK_DELAY 200

void setup() {
  pinMode(LED1_PIN, OUTPUT);
  pinMode(LED2_PIN, OUTPUT);

  digitalWrite(LED1_PIN, LOW);
  digitalWrite(LED2_PIN, LOW);
}

void loop() {
  // вмикаємо перший LED, другий вимикаємо
  digitalWrite(LED1_PIN, HIGH);
  digitalWrite(LED2_PIN, LOW);
  delay(BLINK_DELAY);

  // вимикаємо перший LED, вмикаємо другий
  digitalWrite(LED1_PIN, LOW);
  digitalWrite(LED2_PIN, HIGH);
  delay(BLINK_DELAY);
}
